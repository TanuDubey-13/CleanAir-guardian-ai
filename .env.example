# =========================================================
# CleanAir Guardian AI - Environment Template
# Rename this file to '.env' and populate with your credentials.
# =========================================================

# Google Gemini API Configuration
# Get your key from Google AI Studio: https://aistudio.google.com/
VITE_GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# Google Maps JavaScript API Configuration
# Enable 'Maps JavaScript API' and 'Places API' in Google Cloud Console
VITE_GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY

# Firebase Client SDK Configuration
# Get these credentials from your Firebase project settings console
VITE_FIREBASE_API_KEY=YOUR_FIREBASE_API_KEY
VITE_FIREBASE_AUTH_DOMAIN=YOUR_FIREBASE_AUTH_DOMAIN
VITE_FIREBASE_PROJECT_ID=YOUR_FIREBASE_PROJECT_ID
VITE_FIREBASE_STORAGE_BUCKET=YOUR_FIREBASE_STORAGE_BUCKET
VITE_FIREBASE_MESSAGING_SENDER_ID=YOUR_FIREBASE_MESSAGING_SENDER_ID
VITE_FIREBASE_APP_ID=YOUR_FIREBASE_APP_ID
rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /reports/{userId}/{imageId} {
      // Any authenticated user can view report images
      allow read: if request.auth != null;
      // Users can upload only to their own folder, size < 5MB, and must be verified images
      allow write: if request.auth != null && 
                    request.auth.uid == userId && 
                    request.resource.size < 5 * 1024 * 1024 && 
                    (request.resource.contentType == 'image/png' || 
                     request.resource.contentType == 'image/jpeg' || 
                     request.resource.contentType == 'image/jpg' || 
                     request.resource.contentType == 'image/webp');
    }
  }
}
